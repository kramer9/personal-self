# =============================================================================
# Plex Stack — Environment Variables
# Copy to .env and fill in real values. Never commit .env to git.
# =============================================================================

# NordVPN WireGuard private key
# Get from: https://my.nordaccount.com/dashboard/nordvpn → Set up NordVPN manually → WireGuard
# This is a 44-char base64-encoded 32-byte key tied to your NordVPN account.
PRIVATE_KEY=your_wireguard_private_key_here

# NordVPN access token (used internally by nordlynx for server selection API)
# Get from: https://my.nordaccount.com/dashboard/nordvpn/access-tokens
NORDVPN_TOKEN=your_nordvpn_access_token_here

# Plex claim token — only needed if this is a brand-new unclaimed Plex server.
# Valid for 5 minutes. Get from: https://www.plex.tv/claim
# Leave blank or remove this line if Plex is already claimed.
PLEX_CLAIM=claim-xxxxxxxxxxxxxxxxxxxx
